{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "git-submodules": {
    "enabled": true
  },
  "gitIgnoredAuthors": [
    "github-actions[bot]@users.noreply.github.com"
  ],
  "extends": [
    "config:recommended",
    "config:best-practices",
    "security:openssf-scorecard",
    "helpers:pinGitHubActionDigests",
    ":rebaseStalePrs",
    ":enableVulnerabilityAlerts"
  ],
  "postUpdateOptions": [
    "gomodTidy"
  ],
  "ignorePresets": [
    ":ignoreModulesAndTests"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/test/e2e/.*\\.go$/"
      ],
      "matchStrings": [
        "// renovate: datasource=(?<datasource>[^\\s]+) depName=(?<depName>[^\\s]+)\\s+[^\"]*\"[^:]+:(?<currentValue>[^\"]+)\""
      ]
    }
  ],
  "packageRules": [
    {
      "matchManagers": [
        "gomod"
      ],
      "matchDepNames": [
        "go"
      ],
      "matchDepTypes": [
        "golang"
      ],
      "rangeStrategy": "bump"
    },
    {
      "description": "Group openmcp-project Go components",
      "matchManagers": [
        "gomod"
      ],
      "matchPackageNames": [
        "github.com/openmcp-project/*",
        "openmcp-project/*"
      ],
      "groupName": "openmcp-project Go dependencies",
      "minimumReleaseAge": "0 days",
      "automerge": true
    },
    {
      "description": "Group openmcp-project/build submodule and workflow updates",
      "matchDepNames": [
        "hack/common",
        "openmcp-project/build"
      ],
      "groupName": "openmcp-project/build"
    }
  ]
}